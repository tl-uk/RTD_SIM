"""
visualiser/rail_visualizer.py

Rail visualizer component for Pydeck.

This file is an example. The content are now in unfied in Transit_layers.py.

"""

import pydeck as pdk
import pandas as pd

def create_rail_layer(G_rail):
    """
    Converts a NetworkX rail graph into a Pydeck PathLayer.
    """
    if G_rail is None or len(G_rail.edges()) == 0:
        return None
        
    path_data = []
    
    for u, v, data in G_rail.edges(data=True):
        # 1. Try to use the detailed geometry (curves/tracks) if available
        if 'geometry' in data:
            # OSMnx geometries are usually LineStrings; we need a list of [lon, lat]
            coords = [[float(c[0]), float(c[1])] for c in data['geometry'].coords]
            path_data.append({'path': coords})
        
        # 2. Fallback: Create a straight line between the two nodes
        else:
            u_node = G_rail.nodes[u]
            v_node = G_rail.nodes[v]
            path_data.append({
                'path': [
                    [float(u_node['x']), float(u_node['y'])], 
                    [float(v_node['x']), float(v_node['y'])]
                ]
            })
    
    if not path_data:
        return None

    # Convert to DataFrame for Pydeck performance
    df_rail = pd.DataFrame(path_data)
    
    return pdk.Layer(
        'PathLayer',
        data=df_rail,
        get_path='path',
        # Styling: Dark grey, semi-transparent for a "track" look
        get_color=[80, 80, 80, 180], 
        width_min_pixels=2,
        width_max_pixels=3,
        pickable=False, # Rail tracks usually don't need tooltips
    )