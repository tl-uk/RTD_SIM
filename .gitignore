# ─────────────────────────────────────────────────────────────
# RTD_SIM .gitignore
# ─────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments — never commit these
venv/
.venv/
env/
.env/
ENV/

# Environment variables — contain API keys, never commit
.env
.env.local
.env.*.local

# ─────────────────────────────────────────────────────────────
# RTD_SIM machine-specific config
# Each machine has its own copy of these files.
# Commit the .example versions instead.
# ─────────────────────────────────────────────────────────────
config/ingestion.yaml
config/event_bus.yaml

# ─────────────────────────────────────────────────────────────
# RTD_SIM generated outputs
# These are produced at runtime and differ between machines.
# ─────────────────────────────────────────────────────────────
outputs/
simulation_*.log
combination_report_*.txt
*.log

# OSM network cache — large, regenerated automatically by OSMnx
data/networks/*.graphml
data/networks/*.pkl
data/networks/*.cache

# ─────────────────────────────────────────────────────────────
# IDE and OS
# ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Jupyter (if used)
.ipynb_checkpoints/
*.ipynb

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ─────────────────────────────────────────────────────────────
# Ollama model files — never commit (gigabytes)
# ─────────────────────────────────────────────────────────────
*.gguf
*.bin
models/
